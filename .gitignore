.venv/
__pycache__/
*.pyc
debug-*.log

# Identity + DB under state/ are tracked (AGENTS.md, SOUL.md, USER.md, findings.db, …).
# Ignore volatile runtime dirs only:
state/sessions/
state/memory/
state/audit_trail/
.pulse/
tmp*/
workspace/
# Workspace session notes and captures (last_capture.pcapng at repo root is kept intentionally)
workspace/*.pcapng
workspace/plan.md
workspace/status.md

# Archived session backups and captures
artifacts/archived/

# Ephemeral output reports
output/

# Accidental shell/pip artifacts
1.0.2 --quiet
v

# Watcher runtime logs
watcher/log_initial.txt

# Dev smoke harness temp capture
test_verify.pcapng
capture.pcapng
